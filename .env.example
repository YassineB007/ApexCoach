# Gmail SMTP (use an App Password: Google Account → Security → 2-Step Verification → App passwords)
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Where lead notifications are delivered (defaults to GMAIL_USER if unset)
LEAD_NOTIFY_EMAIL=youraddress@gmail.com

# Optional aliases (if you prefer these names instead — only one set is needed)
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Local ---
# Save as .env.local (gitignored). After editing, restart the dev server (Ctrl+C then npm run dev).

# --- Vercel ---
# Keys: GMAIL_USER, GMAIL_APP_PASSWORD (optional LEAD_NOTIFY_EMAIL). NOT NEXT_PUBLIC_*.
# Enable "Production" (and "Preview" if you test preview URLs). Save, then Deployments → ⋮ → Redeploy.
# Do not wrap values in quotes unless the quotes are part of the secret.

# If SMTP fails with "self-signed certificate in certificate chain" (common with antivirus SSL scanning), set to 1 on your dev PC only — or disable HTTPS scanning in the AV. Do not enable on public servers.
# GMAIL_TLS_INSECURE=1
